# Comma-separated list of origins allowed by CORS.
# Defaults to localhost dev origins if unset.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Path prefix the app is mounted under by an upstream proxy/ingress.
# Leave empty for local/dev. Set to "/extract" when behind the UAT ALB.
ROOT_PATH=

# Maximum upload size in megabytes. Files above this are rejected with
# error="too_large" before MarkItDown is invoked.
MAX_UPLOAD_MB=50

# Per-request extraction timeout in seconds. Files exceeding this return
# error="timeout".
EXTRACTION_TIMEOUT_SECONDS=60

# How many extractions can run in parallel inside a single pod.
# Each extraction is CPU-heavy; 2 is a safe default for a 4 GB pod.
EXTRACTION_CONCURRENCY=2
