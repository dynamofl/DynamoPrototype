# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Supabase Service Role Key (for MCP authentication)
# Get this from your Supabase Dashboard -> Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Supabase MCP token used by the hosted MCP server
# (Personal access token starting with sbp_...). Optional; falls back to a
# baked-in default for local dev only. REQUIRED in deployed environments.
SUPABASE_MCP_TOKEN=sbp_your_token_here

# Supabase MCP server URL (includes project_ref query param). Optional.
SUPABASE_MCP_SERVER_URL=https://mcp.supabase.com/mcp?project_ref=your_project_ref

# Comma-separated list of origins allowed by CORS.
# Defaults to localhost dev origins if unset.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Path prefix the app is mounted under by an upstream proxy/ingress.
# Leave empty for local/dev. Set to "/agent" when behind the UAT ALB.
ROOT_PATH=
